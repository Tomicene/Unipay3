{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Basic user profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Wallet": {
      "title": "Naira Wallet",
      "description": "User wallet containing balance in Naira",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "balance": { "type": "number" },
        "currency": { "type": "string", "enum": ["NGN"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "balance", "currency", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction Record",
      "description": "Records of funding, transfers, and withdrawals",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["FUNDING", "TRANSFER", "WITHDRAWAL"] },
        "status": { "type": "string", "enum": ["PENDING", "SUCCESS", "FAILED"] },
        "reference": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/wallets/{userId}": {
      "schema": "Wallet",
      "description": "User wallet balance"
    },
    "/transactions/{txnId}": {
      "schema": "Transaction",
      "description": "Transaction logs"
    }
  }
}
